# ─── Local Development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Database — leave blank to use local SQLite
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Allowed frontend origins (comma-separated)
FRONTEND_URL=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Vercel Production Environment Variables ──────────────────────────────────
# Set ALL of the following in your Vercel project:
#   Dashboard → Your Project → Settings → Environment Variables
#
# SECRET_KEY            = <generate with: python -c "import secrets; print(secrets.token_hex(50))">
# DEBUG                 = False
# DATABASE_URL          = postgres://... (Neon / Supabase / Railway free tier)
#                         ↑ If left empty Vercel uses SQLite in /tmp (data resets on cold start)
# FRONTEND_URL          = https://your-app.vercel.app   (or Expo URL)
# DJANGO_CSRF_TRUSTED_ORIGINS = https://your-app.vercel.app
#
# ─── Admin user bootstrap (set once, then you can remove) ────────────────────
# BOOTSTRAP_ADMIN_USERNAME = admin
# BOOTSTRAP_ADMIN_PASSWORD = YourStrongPassword123
# BOOTSTRAP_ADMIN_EMAIL    = you@example.com
