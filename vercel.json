{
  "version": 2,
  "builds": [
    {
      "src": "bszone_backend/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "200mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "bszone_backend/wsgi.py"
    }
  ],
  "buildCommand": "bash build_files.sh"
}
